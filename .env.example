# VLM provider. This project supports OpenRouter without modifying ai/
LLM_PROVIDER=openrouter
LLM_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_REASONING_ENABLED=false

# Alternative providers still supported by the provided ai/ package:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# LLM_PROVIDER=openai
# OPENAI_API_KEY=
# LLM_PROVIDER=gemini
# GOOGLE_API_KEY=

# Nutrition provider
NUTRITION_PROVIDER=usda
USDA_API_KEY=

# Runtime
LOG_LEVEL=INFO
OFFLINE_MODE=false
HTTP_PORT=8000
MAX_IMAGE_SIZE_MB=5
MAX_PARALLEL_LOOKUPS=10
AI_TIMEOUT_SECONDS=30
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=0.2
RATE_LIMIT_TOKENS=10
RATE_LIMIT_REFILL_PER_SECOND=10
NUTRITION_CACHE_BACKEND=postgres
NUTRITION_CACHE_TTL_SECONDS=86400

# Storage
# For offline demos without PostgreSQL, override with STORAGE_BACKEND=jsonl
STORAGE_BACKEND=postgres
HISTORY_JSONL_PATH=artefacts/history.jsonl
UPLOAD_DIR=runtime/uploads
DATABASE_URL=postgresql://postgres:dev@localhost:5432/foodanalyzer
