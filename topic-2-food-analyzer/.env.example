# Copy this to .env and fill in real values. DO NOT commit .env.

# --- VLM (for ingredient identification) ---
LLM_PROVIDER=anthropic        # anthropic | openai | gemini
LLM_MODEL=claude-sonnet-4-6   # provider-specific model id
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# --- Nutrition provider ---
NUTRITION_PROVIDER=usda
USDA_API_KEY=                 # free key from https://fdc.nal.usda.gov/api-key-signup

# --- SE-layer settings (you will populate these) ---
LOG_LEVEL=INFO
# PostgreSQL connection string. For asyncpg, use the postgresql+asyncpg:// scheme.
# Spin up a local server with docker: `docker run -d --name pg -e POSTGRES_PASSWORD=dev -p 5432:5432 postgres:16`
DATABASE_URL=postgresql+asyncpg://postgres:dev@localhost:5432/foodanalyzer
NUTRITION_CACHE_TTL_SECONDS=86400
MAX_IMAGE_SIZE_MB=5
HTTP_PORT=8000
